# =========================
# Public app URL (web)
# =========================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================
# Worker -> API target
# Set this to your Vercel URL when worker runs on laptop/server
# Example: https://your-app.vercel.app
# =========================
INTERNAL_API_BASE_URL=http://localhost:3000

APP_TIMEZONE=Asia/Jakarta

# =========================
# Database (Supabase + Prisma)
# =========================
# Runtime DB URL (can use Supabase transaction pooler 6543)
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# Direct/session URL for Prisma schema operations (db push/migrate)
DIRECT_URL=postgresql://postgres.your-project-ref:your-db-password@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?sslmode=require&pgbouncer=true&connection_limit=1

# =========================
# AI provider (OpenAI compatible)
# =========================
OPENAI_API_KEY=your-ai-api-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=stepfun/step-3.5-flash:free
# Optional override specifically for parser quality testing
OPENAI_PARSER_MODEL=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=AI Student Assistant
AI_MONTHLY_TOKEN_BUDGET=250000

# =========================
# NextAuth (Discord login)
# =========================
AUTH_SECRET=your-random-long-secret
AUTH_DISCORD_ID=your-discord-oauth-client-id
AUTH_DISCORD_SECRET=your-discord-oauth-client-secret

# =========================
# Discord messaging
# =========================
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_ALLOWED_USER_ID=
DISCORD_COMMAND_NAME=assistant

# Optional fallback channel when user_id mapping is unavailable
DISCORD_OUTBOUND_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# Optional direct URL for dashboard "Chat Bot" button
NEXT_PUBLIC_DISCORD_BOT_DM_URL=https://discord.com/users/123456789012345678

# =========================
# Internal security tokens (must match between API + worker)
# =========================
REMINDER_RUN_AUTH_TOKEN=change-me-reminder-job-token
API_INTERNAL_AUTH_TOKEN=change-me-internal-api-token

# Worker polling settings
REMINDER_POLL_INTERVAL_MS=15000
REMINDER_MAX_LAG_MINUTES=30
# =========================
# Indonesia holidays sync (libur.deno.dev)
# =========================
HOLIDAY_PROVIDER_BASE_URL=https://libur.deno.dev
HOLIDAY_SYNC_YEARS_PAST=0
HOLIDAY_SYNC_YEARS_FUTURE=1

